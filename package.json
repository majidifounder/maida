{
  "name": "restaurant-platform",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev":       "turbo run dev",
    "build":     "turbo run build",
    "lint":      "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test":      "turbo run test",
    "redis:up":   "docker compose up -d redis",
    "redis:down": "docker compose down",
    "db:up":      "docker compose up -d redis",
    "db:down":    "docker compose down",
    "db:migrate":        "tsx scripts/db-migrate.ts",
    "db:migrate:deploy": "pnpm --filter @restaurant/db db:migrate:deploy",
    "db:generate":       "pnpm --filter @restaurant/db db:generate",
    "db:generate:win":   "powershell -ExecutionPolicy Bypass -File scripts/db-generate-win.ps1",
    "db:seed":    "pnpm --filter @restaurant/db db:seed",
    "db:studio":  "pnpm --filter @restaurant/db db:studio",
    "db:reset":   "pnpm --filter @restaurant/db db:reset",
    "load-test":  "tsx scripts/load-test.ts",
    "e2e":        "tsx scripts/e2e/run.ts",
    "check-env":  "tsx scripts/check-env.ts",
    "db:export":    "tsx scripts/export-backup.ts",
    "db:restore":   "tsx scripts/restore-backup.ts",
    "db:dev-reset": "tsx scripts/dev-data-reset.ts"
  },
  "devDependencies": {
    "@restaurant/db":                "workspace:*",
    "@types/ws":                     "^8.18.1",
    "bcryptjs":                      "^2.4.3",
    "dotenv":                        "^17.4.2",
    "jsonwebtoken":                  "^9.0.3",
    "otplib":                        "^12.0.1",
    "tsx":                           "^4.22.4",
    "undici":                        "^7.16.0",
    "ws":                            "^8.18.3",
    "turbo":                           "latest",
    "typescript":                      "^5.4.0",
    "eslint":                          "^8.57.0",
    "@typescript-eslint/eslint-plugin":"^7.0.0",
    "@typescript-eslint/parser":       "^7.0.0",
    "prettier":                        "^3.9.0"
  }
}
