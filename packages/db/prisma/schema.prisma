generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // directUrl used for migrations only (bypasses PgBouncer pooling)
  directUrl  = env("DIRECT_DATABASE_URL")
  extensions = [pgcrypto, pg_trgm, citext, btree_gist]
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  DINER
  OWNER
  ADMIN
}

enum CuisineType {
  ITALIAN
  FRENCH
  JAPANESE
  CHINESE
  INDIAN
  MEXICAN
  MEDITERRANEAN
  AMERICAN
  THAI
  OTHER
}

enum Plan {
  STARTER
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAUSED
  PAST_DUE
  CANCELLED
  EXPIRED
}

// LOCKED  — furniture is fixed; a table is fully occupied by its reservation.
// FLEXIBLE — owner-predefined combinations of tables are additionally bookable.
enum SeatingMode {
  LOCKED
  FLEXIBLE
}

enum ReservationStatus {
  SCHEDULED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// STANDARD — duration derived from the restaurant's turn-time configuration.
// CUSTOM   — diner or staff explicitly chose the duration (plan-gated, may carry fees).
enum ReservationType {
  STANDARD
  CUSTOM
}

// ONLINE  — created by a diner through the diner app.
// WALK_IN — created by staff for a party physically present (seated immediately).
// STAFF   — created by staff on behalf of a guest for a future time (incl. overrides).
enum ReservationSource {
  ONLINE
  WALK_IN
  STAFF
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique @db.Citext   // citext = case-insensitive, prevents duplicates like User@Example.com
  password  String                        // bcrypt hash — NEVER returned in API responses
  role      Role     @default(DINER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt  DateTime?                    // soft delete — user data retained for audit
  totpSecret String?                      // null until admin completes TOTP setup

  // Relations
  reservations Reservation[]
  restaurants  Restaurant[]
  sessions     RefreshToken[]
  subscription Subscription?
  feedback     ProductFeedback[]

  @@index([email])
  @@index([role])
  @@map("users")
}

// ─── REFRESH TOKEN (token revocation store) ───────────────────────────────────

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jti       String   @unique               // JWT ID — used for fast revocation lookup
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String                         // SHA-256 of the raw refresh token — never store raw
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?                      // null = active, non-null = revoked

  @@index([userId])
  @@index([jti])
  @@index([expiresAt])                     // for cleanup jobs (purge expired tokens)
  @@map("refresh_tokens")
}

// ─── RESTAURANT ───────────────────────────────────────────────────────────────

model Restaurant {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId     String      @db.Uuid
  owner       User        @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  name        String      @db.VarChar(120)
  slug        String      @unique @db.VarChar(140)  // URL-safe identifier, e.g. "bistro-on-main-sf"
  cuisine     CuisineType
  description String      @db.VarChar(1000)
  address     String      @db.VarChar(300)
  city        String      @db.VarChar(100)
  phone       String?     @db.VarChar(20)
  imageUrl    String?
  isActive    Boolean     @default(true)             // owner can deactivate without deleting
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  // ── Reservation engine configuration ──────────────────────────────────────
  timezone             String      @default("UTC") @db.VarChar(64) // IANA, e.g. America/New_York
  seatingMode          SeatingMode @default(LOCKED)
  defaultDurationMins  Int         @default(90)      // fallback turn time for standard reservations
  // Legacy "simple" service window — kept as the coarse day span for display and as the
  // seed used to generate the per-weekday ServicePeriod rows. The reservation engine reads
  // ServicePeriod / RestaurantClosure, falling back to these columns only when a restaurant
  // has no ServicePeriod rows at all (belt-and-suspenders for pre-schedule data).
  openMinutes          Int         @default(660)     // service window start, minutes from local midnight
  closeMinutes         Int         @default(1380)    // service window end, minutes from local midnight
  // Informational fees — displayed to the diner, charged AT the restaurant.
  // Maida never collects, processes, holds, or disburses this money.
  customFee    Decimal? @db.Decimal(10, 2)           // flat fee for a custom-duration reservation
  extraHourFee Decimal? @db.Decimal(10, 2)           // rate per additional hour beyond the standard turn time
  feeCurrency  String   @default("USD") @db.VarChar(3)
  maxExtraHours Int     @default(2)                  // cap on hours beyond standard turn for CUSTOM reservations

  // Relations
  tables         DiningTable[]
  combinations   TableCombination[]
  turnTimeRules  TurnTimeRule[]
  reservations   Reservation[]
  servicePeriods ServicePeriod[]
  closures       RestaurantClosure[]

  @@index([ownerId])
  @@index([isActive])
  @@index([city, isActive])               // primary search query: city + active
  @@index([cuisine, isActive])
  // trgm index added in raw migration for name ILIKE search
  @@map("restaurants")
}

// ─── SERVICE PERIOD (weekly opening schedule) ─────────────────────────────────
// One row per bookable window on a given weekday. A restaurant may have several
// rows per weekday (e.g. a lunch window and a dinner window) and none at all on
// a closed weekday. `closeMinute <= openMinute` means the window runs past local
// midnight into the following calendar day (overnight service, e.g. 18:00–02:00).

model ServicePeriod {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dayOfWeek    Int        // 0 = Sunday … 6 = Saturday (matches JS Date.getUTCDay of the calendar date)
  openMinute   Int        // minutes from local midnight, 0–1439
  closeMinute  Int        // 1–1440; if <= openMinute, the window continues into the next local day
  createdAt    DateTime   @default(now())

  @@index([restaurantId, dayOfWeek])
  @@map("service_periods")
}

// ─── RESTAURANT CLOSURE (blackout dates) ──────────────────────────────────────
// A specific local calendar day on which the restaurant accepts no new service.
// Overnight windows that START on an open day may still run into a closure day —
// a closure only suppresses windows that START on that date.

model RestaurantClosure {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  date         DateTime   @db.Date
  reason       String?    @db.VarChar(200)
  createdAt    DateTime   @default(now())

  @@unique([restaurantId, date])
  @@index([restaurantId, date])
  @@map("restaurant_closures")
}

// ─── DINING TABLE (atomic physical unit) ──────────────────────────────────────
// The discrete bookable resource. Availability is computed by real interval
// overlap against these units — never by pooled seat/table counters.

model DiningTable {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String     @db.VarChar(60)     // e.g. "Table 5", "Booth A", "Patio 2"
  minPartySize Int        @default(1)         // owner-configured smallest party this unit serves
  maxPartySize Int                            // owner-configured largest party this unit serves
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  combinationMembers TableCombinationMember[]
  reservationTables  ReservationTable[]

  @@unique([restaurantId, name])
  @@index([restaurantId, isActive])
  @@map("dining_tables")
}

// ─── TABLE COMBINATION (owner-predefined merge, FLEXIBLE mode only) ───────────
// A bookable unit in its own right. Reserving it locks every member table for
// the reservation interval. Combinations are pre-defined by the owner — never
// computed dynamically at booking time.

model TableCombination {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String     @db.VarChar(60)     // e.g. "Tables 4+5 (window row)"
  minPartySize Int        @default(1)
  maxPartySize Int
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  members TableCombinationMember[]

  @@unique([restaurantId, name])
  @@index([restaurantId, isActive])
  @@map("table_combinations")
}

model TableCombinationMember {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  combinationId String           @db.Uuid
  combination   TableCombination @relation(fields: [combinationId], references: [id], onDelete: Cascade)
  tableId       String           @db.Uuid
  table         DiningTable      @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([combinationId, tableId])
  @@index([tableId])
  @@map("table_combination_members")
}

// ─── TURN TIME RULE (default duration by party size band) ─────────────────────
// Standard reservations derive their end time from the first matching rule;
// the restaurant's defaultDurationMins is the fallback.

model TurnTimeRule {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  minPartySize Int
  maxPartySize Int
  durationMins Int
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
  @@map("turn_time_rules")
}

// ─── RESERVATION (time-range occupation of physical resources) ────────────────

model Reservation {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  restaurantId String            @db.Uuid
  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  dinerId      String?           @db.Uuid      // null for staff-created walk-ins without an account
  diner        User?             @relation(fields: [dinerId], references: [id], onDelete: Restrict)

  partySize Int
  startsAt  DateTime @db.Timestamptz(3)
  endsAt    DateTime @db.Timestamptz(3)

  status          ReservationStatus @default(SCHEDULED)
  reservationType ReservationType   @default(STANDARD)
  source          ReservationSource @default(ONLINE)

  guestName String? @db.VarChar(120)           // walk-in / staff-created party name
  notes     String? @db.VarChar(500)

  // Informational fee snapshot taken at booking time (see Restaurant fee fields).
  customFeeSnapshot    Decimal? @db.Decimal(10, 2)
  extraHourFeeSnapshot Decimal? @db.Decimal(10, 2)
  feeCurrency          String?  @db.VarChar(3)
  untilClose           Boolean  @default(false)      // server-computed end for "reserve until close" bookings

  isOverride Boolean @default(false)           // created via the explicit staff override path

  seatedAt     DateTime? @db.Timestamptz(3)
  completedAt  DateTime? @db.Timestamptz(3)
  cancelledAt  DateTime? @db.Timestamptz(3)
  cancelReason String?   @db.VarChar(300)
  noShowAt     DateTime? @db.Timestamptz(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tables ReservationTable[]

  @@index([dinerId, status])
  @@index([restaurantId, startsAt])
  @@index([restaurantId, status])
  @@index([restaurantId, createdAt(sort: Desc)])
  @@map("reservations")
}

// ─── RESERVATION TABLE HOLD ───────────────────────────────────────────────────
// One row per atomic table a reservation occupies, carrying the occupied
// interval. Protected by a PostgreSQL GiST EXCLUSION constraint (added in raw
// migration SQL — Prisma cannot express it):
//
//   EXCLUDE USING gist ("tableId" WITH =, tstzrange("startsAt","endsAt",'[)') WITH &&)
//   WHERE ("releasedAt" IS NULL)
//
// This makes overlapping holds on the same physical table IMPOSSIBLE BY
// CONSTRUCTION at the database layer, regardless of code path or concurrency.

model ReservationTable {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId String      @db.Uuid
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  tableId       String      @db.Uuid
  table         DiningTable @relation(fields: [tableId], references: [id], onDelete: Restrict)
  startsAt      DateTime  @db.Timestamptz(3)    // kept in lockstep with the parent reservation
  endsAt        DateTime  @db.Timestamptz(3)
  releasedAt    DateTime? @db.Timestamptz(3)     // set on cancel/no-show — frees the interval

  @@unique([reservationId, tableId])
  @@index([tableId, startsAt])
  @@map("reservation_tables")
}

// ─── AUDIT LOG ────────────────────────────────────────────────────────────────
// Append-only. Never updated or deleted. Required for compliance and forensics.

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?  @db.Uuid           // null for system events or unauthenticated actions
  actorRole  Role?
  action     String   @db.VarChar(100)   // e.g. "reservation.created", "auth.login.failed"
  entityType String   @db.VarChar(50)    // e.g. "reservation", "user", "restaurant"
  entityId   String?  @db.Uuid
  metadata   Json?                        // any extra context (IP, user agent, diff)
  ipAddress  String?  @db.VarChar(45)    // IPv6-safe
  userAgent  String?  @db.VarChar(300)
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ─── SUBSCRIPTION ─────────────────────────────────────────────────────────────

model Subscription {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan   Plan   @default(STARTER)

  // Lemon Squeezy fields — null until payment integration is added
  lemonSqueezyId        String?
  lemonSqueezyOrderId   String?
  lemonSqueezyProductId String?
  lemonSqueezyVariantId String?
  currentPeriodEnd      DateTime?
  renewsAt              DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  status                SubscriptionStatus @default(ACTIVE)
  trialStartedAt        DateTime?          @db.Timestamptz
  // Timestamp of the last Lemon Squeezy event applied to this row. Webhook events
  // whose attributes.updated_at is older than this are ignored, so out-of-order
  // deliveries cannot regress billing state.
  lsUpdatedAt           DateTime?          @db.Timestamptz

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

// ─── PRODUCT FEEDBACK (internal — admin only) ────────────────────────────────

model ProductFeedback {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role
  message   String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([createdAt])
  @@index([userId])
  @@map("product_feedback")
}
