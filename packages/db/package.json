{
  "name": "@restaurant/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate":       "dotenv -e ../../.env -- prisma generate",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:test":   "dotenv -e ../../.env.test -- prisma migrate deploy",
    "db:migrate":        "dotenv -e ../../.env -- prisma migrate deploy && dotenv -e ../../.env -- prisma generate",
    "db:push":      "dotenv -e ../../.env -- prisma db push",
    "db:studio":    "dotenv -e ../../.env -- prisma studio",
    "db:seed":      "dotenv -e ../../.env -- tsx src/seed.ts",
    "db:reset":     "dotenv -e ../../.env -- prisma migrate reset --force && dotenv -e ../../.env -- tsx src/seed.ts",
    "lint":         "eslint src --ext .ts",
    "typecheck":    "tsc --noEmit",
    "build":        "tsc"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "prisma":    "^7.8.0",
    "tsx":       "^4.15.0",
    "@faker-js/faker": "^10.5.0",
    "@types/node": "^26.1.1",
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv-cli": "^11.0.0"
  }
}
