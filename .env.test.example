# ─────────────────────────────────────────────────────────────────────────────
# Maida — TEST environment template.  Copy to `.env.test`.
#
# `pnpm test` and `pnpm e2e` load THIS file (not `.env`). It MUST point at
# throwaway TEST databases — the suites create AND DELETE rows. Never put
# production credentials here.
#
# The sentinel TEST_DATABASE=true below is a hard safety gate: the test runner
# refuses to start unless it is set, and production environments (Railway) never
# set it — so `pnpm test` / `pnpm e2e` can never touch prod. See
# LAUNCH_CHECKLIST.md → "Test vs Production environments".
# ─────────────────────────────────────────────────────────────────────────────

# ── SAFETY GATE — do not remove ───────────────────────────────────────────────
# Proves this env points at a disposable test database. Required to run the suites.
TEST_DATABASE=true
NODE_ENV=test

# ── Database — Supabase Postgres (a SEPARATE project from production) ──────────
# Create a second, free Supabase project just for testing. Same "Connect" flow
# as prod: Transaction pooler (6543, add ?pgbouncer=true&connection_limit=10)
# for DATABASE_URL, Session pooler (5432) for DIRECT_DATABASE_URL.
# Apply the schema once:  pnpm --filter @restaurant/db db:migrate:deploy
DATABASE_URL=
DIRECT_DATABASE_URL=

# ── Redis — Upstash (a SEPARATE database from production) ──────────────────────
# A second free Upstash database. Or local Docker: `pnpm redis:up` then
#   redis://default:devredispass@localhost:6379
REDIS_URL=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Test-only keys — never reuse prod keys. Lower rounds keep the suite fast.
BCRYPT_ROUNDS=10
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
QUEUE_NAME=booking_events_test
WEB_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174

# ── Email — Resend (sandbox; test emails only reach your own Resend address) ───
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# ── Billing — Lemon Squeezy (test/placeholder values are fine) ─────────────────
LEMON_SQUEEZY_API_KEY=test_key
LEMON_SQUEEZY_STORE_ID=1
LEMON_SQUEEZY_WEBHOOK_SECRET=test_secret
LS_VARIANT_STARTER=100
LS_VARIANT_PRO=200
LS_VARIANT_PREMIUM=300

# Local Redis password (only used by `pnpm redis:up`).
REDIS_PASSWORD=devredispass
