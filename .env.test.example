# ─────────────────────────────────────────────────────────────────────────────
# Maida — TEST environment template.  Copy to `.env.test`.
#
# `pnpm test` and `pnpm e2e` load THIS file (not `.env`), and it points at LOCAL
# DOCKER containers only — never staging, never production. The suites CREATE
# AND DELETE rows, so they must never reach a shared or remote database.
#
#   pnpm db:up             # start Docker postgres + redis (docker-compose.yml)
#   pnpm db:migrate:test   # apply the schema to the local test database
#   pnpm test
#
# The image and credentials below mirror the `services:` block in
# .github/workflows/ci.yml, so a green local run means a green CI run.
#
# The sentinel TEST_DATABASE=true below is a hard safety gate: the runners refuse
# to start unless it is set, and production (Railway) never sets it — so the
# destructive suites can never touch prod. See LAUNCH_CHECKLIST_V2.md → 2.1.
# ─────────────────────────────────────────────────────────────────────────────

# ── SAFETY GATE — do not remove ───────────────────────────────────────────────
# Proves this env points at a disposable test database. Required to run the suites.
TEST_DATABASE=true
NODE_ENV=test

# ── Database — local Docker Postgres (`postgres` service) ─────────────────────
# postgres:16-alpine, user/password `postgres`, database `maida_test` — identical
# to CI. There is no connection pooler locally, so DATABASE_URL and
# DIRECT_DATABASE_URL are the same value (on Supabase they differ: pooler vs direct).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/maida_test
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/maida_test

# ── Redis — local Docker Redis (`redis` service) ──────────────────────────────
# This password must match REDIS_PASSWORD in `.env` — that is the only file Docker
# Compose interpolates from; it never reads `.env.test`. The value below is the
# compose fallback used when `.env` does not set it.
REDIS_URL=redis://default:devredispass@localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Test-only keys — never reuse prod keys. Lower rounds keep the suite fast.
# Generate a throwaway RS256 pair (prints two JSON-quoted one-liners):
#   node -e "const{generateKeyPairSync}=require('crypto');const{privateKey,publicKey}=generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});console.log(JSON.stringify(privateKey));console.log(JSON.stringify(publicKey))"
BCRYPT_ROUNDS=10
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
QUEUE_NAME=booking_events_test
WEB_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174

# ── Email — Resend (sandbox; test emails only reach your own Resend address) ───
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# ── Billing — Lemon Squeezy (test/placeholder values are fine) ─────────────────
LEMON_SQUEEZY_API_KEY=test_key
LEMON_SQUEEZY_STORE_ID=1
LEMON_SQUEEZY_WEBHOOK_SECRET=test_secret
LS_VARIANT_STARTER=100
LS_VARIANT_PRO=200
LS_VARIANT_PREMIUM=300
