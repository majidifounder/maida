# Supabase PostgreSQL (Project Settings → Database → Connection string)
# IMPORTANT: URL-encode your password if it contains $ ! * @ #  etc.
#   $ → %24   ! → %21   * → %2A   @ → %40
# Pooled URL — transaction pooler (port 6543) — use for the running API
DATABASE_URL=

# Direct URL — session pooler (port 5432) on pooler.supabase.com — use for Prisma migrations
# and for backup/restore scripts (pnpm db:export, db:restore, db:dev-reset)
# (Avoid db.[ref].supabase.co on Windows — often IPv6-only and fails with P1001)
DIRECT_DATABASE_URL=

# Supabase project (optional — storage/realtime later; auth is custom JWT, not Supabase Auth)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (Upstash in staging/prod — or local Docker via `pnpm redis:up`)
REDIS_URL=

# ── Auth service ──────────────────────────────────────────────────────────────
# Number of bcrypt rounds (10–14 recommended; 12 is the production default)
BCRYPT_ROUNDS=12

# Comma-separated list of allowed CORS origins (no trailing slashes)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── RS256 key pair ────────────────────────────────────────────────────────────
# Option A — OpenSSL (Git Bash: "C:\Program Files\Git\usr\bin\openssl.exe"):
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Option B — Node.js (no OpenSSL required; from repo root):
#   node -e "const {generateKeyPairSync}=require('crypto');const fs=require('fs');const {privateKey,publicKey}=generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});let env=fs.readFileSync('.env','utf8');env=env.replace(/^JWT_PRIVATE_KEY=.*$/m,'JWT_PRIVATE_KEY='+JSON.stringify(privateKey.trim()));env=env.replace(/^JWT_PUBLIC_KEY=.*$/m,'JWT_PUBLIC_KEY='+JSON.stringify(publicKey.trim()));fs.writeFileSync('.env',env);console.log('JWT keys written to .env');"
# Paste PEM contents below, or use Option B to write directly to .env.
# In CI/CD: store each key with literal \n for newlines (the app normalises them).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# App
NODE_ENV=development
PORT=3001

# Queue
QUEUE_NAME=booking_events

# Notification service (Phase 5)
RESEND_API_KEY=
EMAIL_FROM=reservations@restaurant-booking.app

# Cloudflare Turnstile — server-side verification secret
# Get from: Cloudflare Dashboard → Turnstile → your widget → Secret Key
# Leave unset in development — Turnstile verification is skipped when absent
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Shared secret between Cloudflare and origin (blocks direct origin access)
# Set to any long random string (e.g. openssl rand -hex 32)
# Same value must be set in Cloudflare Transform Rule (see LAUNCH_CHECKLIST.md)
# Leave unset in development
CF_ORIGIN_SECRET=

# Local Redis only (docker-compose.yml — not needed when using Upstash)
REDIS_PASSWORD=devredispass

# Password reset URLs — used to build links in reset emails
WEB_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174

# Billing — Lemon Squeezy (Phase 11)
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret
LEMON_SQUEEZY_API_KEY=your_api_key
LEMON_SQUEEZY_STORE_ID=12345
LS_VARIANT_STARTER=100
LS_VARIANT_PRO=200
LS_VARIANT_PREMIUM=300

# ── Operations ────────────────────────────────────────────────────────────────
# Run the notification/maintenance workers inside the API process (default true).
# Set to false in production and run `pnpm --filter @restaurant/api worker` as a
# separate service so an email backlog or worker crash cannot degrade the API.
RUN_WORKER_IN_PROCESS=true

# Optional: Slack-compatible incoming webhook for critical alerts (worker
# failures, uncaught exceptions). Unset = alerts are error-level logs only.
ALERT_WEBHOOK_URL=

# Audit log retention in days (min 30, default 365) — enforced by the daily
# maintenance job.
AUDIT_LOG_RETENTION_DAYS=365

# Cloudflare R2 — restaurant logo uploads (optional in dev; logos save to apps/api/uploads/ instead)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
