# Database
DATABASE_URL=postgresql://restaurant:devpassword@localhost:5432/restaurant_dev

# Database (separate URLs for pooled vs direct connections)
DIRECT_DATABASE_URL=postgresql://restaurant:devpassword@localhost:5432/restaurant_dev

# Docker local dev
POSTGRES_USER=restaurant
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=restaurant_dev
REDIS_PASSWORD=devredispass

# Redis
REDIS_URL=

# Auth (RS256 key pair — generate with: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# App
NODE_ENV=development
PORT=3001

# Queue
QUEUE_NAME=booking_events
