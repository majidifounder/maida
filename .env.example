# ─────────────────────────────────────────────────────────────────────────────
# Maida API — environment template.  Copy to `.env` for local dev.
# `.env` is git-ignored; NEVER commit real secrets. Full reference + where to
# obtain every value: LAUNCH_CHECKLIST.md § 3.
# Required vars are validated on boot by apps/api/src/env.ts — the server refuses
# to start if any are missing.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database — Supabase Postgres ──────────────────────────────────────────────
# Supabase → your project → "Connect" button.
#   DATABASE_URL         = Transaction pooler (port 6543). MUST end with
#                          ?pgbouncer=true&connection_limit=10 (Prisma prepared
#                          statements break on the pooler without it).
#   DIRECT_DATABASE_URL  = Session pooler (port 5432) — used for migrations only.
# URL-encode the password if it contains @ : / ? # ! $ * &  (e.g. @ → %40).
DATABASE_URL=
DIRECT_DATABASE_URL=

# ── Redis — Upstash ───────────────────────────────────────────────────────────
# Upstash → your database → copy the rediss:// URL.
# Set the database's eviction policy to `noeviction` in the Upstash console.
# For local dev instead, run `pnpm redis:up` (Docker) and use:
#   redis://default:devredispass@localhost:6379
REDIS_URL=

# ── Auth ──────────────────────────────────────────────────────────────────────
# bcrypt cost (10–14; 12 is the production default)
BCRYPT_ROUNDS=12

# Comma-separated allowed CORS origins (no trailing slashes). This dev default
# covers the three local frontends. In prod: your real domains, NO localhost.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# RS256 key pair (generate — do NOT reuse across environments):
#   Option A (OpenSSL):
#     openssl genrsa -out private.pem 2048
#     openssl rsa -in private.pem -pubout -out public.pem
#   Option B (Node, writes both keys straight into .env, no OpenSSL needed):
#     node -e "const {generateKeyPairSync}=require('crypto');const fs=require('fs');const {privateKey,publicKey}=generateKeyPairSync('rsa',{modulusLength:2048,publicKeyEncoding:{type:'spki',format:'pem'},privateKeyEncoding:{type:'pkcs8',format:'pem'}});let e=fs.readFileSync('.env','utf8');e=e.replace(/^JWT_PRIVATE_KEY=.*$/m,'JWT_PRIVATE_KEY='+JSON.stringify(privateKey.trim()));e=e.replace(/^JWT_PUBLIC_KEY=.*$/m,'JWT_PUBLIC_KEY='+JSON.stringify(publicKey.trim()));fs.writeFileSync('.env',e);console.log('JWT keys written to .env');"
# In CI/host env, store each key with literal \n for newlines (the app normalises them).
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
QUEUE_NAME=booking_events

# Frontend URLs — used to build links in verification / password-reset emails.
WEB_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174

# ── Email — Resend ────────────────────────────────────────────────────────────
# Resend → API Keys → Create (starts with "re_").
RESEND_API_KEY=
# Sender address. `onboarding@resend.dev` works immediately in Resend sandbox
# (delivers only to your own Resend account email). In prod use a verified
# domain address, e.g. noreply@yourdomain.com (see LAUNCH_CHECKLIST.md § C6).
EMAIL_FROM=onboarding@resend.dev

# ── Billing — Lemon Squeezy ───────────────────────────────────────────────────
# Lemon Squeezy → Settings.
#   API_KEY        : Settings → API → create key.
#   STORE_ID       : Settings → Stores → numeric ID.
#   WEBHOOK_SECRET : Settings → Webhooks → your webhook's signing secret.
# These are REQUIRED for the API to boot. For local dev without a real store,
# any non-empty placeholder lets the server start (billing calls will fail).
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
# Variant IDs: Products → open each subscription variant → copy its numeric ID.
LS_VARIANT_STARTER=
LS_VARIANT_PRO=
LS_VARIANT_PREMIUM=

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Turnstile bot check (server-side secret). Cloudflare → Turnstile → widget →
# Secret Key. Leave unset in dev — verification is skipped when absent.
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Shared secret proving a request came through Cloudflare (blocks direct origin
# access). REQUIRED in production (min 32 chars). Generate: openssl rand -hex 32
# Set the SAME value in the Cloudflare Transform Rule (x-cf-origin-secret).
# Leave unset in dev.
CF_ORIGIN_SECRET=

# ── Operations ────────────────────────────────────────────────────────────────
# Run the notification/maintenance workers inside the API process (default true).
# Keep true for a single-service deploy. Set false only if you run
# `pnpm --filter @restaurant/api worker` as a separate service.
RUN_WORKER_IN_PROCESS=true

# Optional Slack-compatible incoming webhook for critical alerts (worker
# failures, uncaught exceptions). Unset = alerts are error-level logs only.
ALERT_WEBHOOK_URL=

# Audit-log retention in days (min 30, default 365) — enforced by the daily
# maintenance job.
AUDIT_LOG_RETENTION_DAYS=365

# Local Redis password (only used by docker-compose.yml / `pnpm redis:up`).
REDIS_PASSWORD=devredispass

# ── Cloudflare R2 — restaurant logo uploads (optional) ────────────────────────
# Unset in dev → logos save to apps/api/uploads/ on local disk. On a stateless
# prod host, set all five so uploads persist. Cloudflare → R2 → create bucket +
# an API token (Account ID, Access Key, Secret); R2_PUBLIC_URL is the bucket's
# public/custom-domain URL.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
