# Diner web app (Phase 6)
# Leave blank to use the Vite dev-server proxy (/api → localhost:3001)
VITE_API_URL=

# Cloudflare Turnstile — client-side site key (safe to expose publicly)
# Get from: Cloudflare Dashboard → Turnstile → your widget → Site Key
# Development: use Cloudflare always-pass test key
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
