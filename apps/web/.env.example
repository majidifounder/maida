# Diner web app (Vite build-time vars).
# Leave VITE_API_URL blank in local dev — the Vite proxy forwards /api → localhost:3001.
# In staging/prod set it to the API's public URL, e.g. https://api.yourdomain.com
# (set this in the frontend host's env, then redeploy — Vite bakes it in at build time).
VITE_API_URL=

# Cloudflare Turnstile — client-side site key (public; safe to expose).
# Get from: Cloudflare Dashboard → Turnstile → your widget → Site Key.
# The value below is Cloudflare's always-pass TEST key for local dev.
VITE_CLOUDFLARE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
