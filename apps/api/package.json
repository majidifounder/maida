{
  "name": "@restaurant/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "dev:test": "dotenv -e ../../.env.test -- tsx src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "worker": "dotenv -e ../../.env -- tsx src/worker.ts",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "admin:totp-setup": "tsx scripts/admin-totp-setup.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@fastify/cookie": "^11.1.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/sensible": "^6.0.3",
    "@fastify/websocket": "^11.3.0",
    "@restaurant/db": "workspace:*",
    "@restaurant/types": "workspace:*",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.80.8",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^12.0.1",
    "pino": "^9.0.0",
    "qrcode": "^1.5.4",
    "resend": "^6.17.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^7.4.4",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.4.0",
    "undici": "^7.16.0",
    "vitest": "^4.1.10"
  }
}
